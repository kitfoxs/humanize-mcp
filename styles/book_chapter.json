{
  "name": "book_chapter",
  "description": "Long-form non-fiction book chapter. Conversational but authoritative. Em dashes mostly removed (small number kept for cadence). Modest contractions. Modest hedges. Tricolons dampened only when stacked. Voice openers limited to book-narration tone.",
  "target_register": "neutral",
  "passes_enabled": [
    1,
    2,
    3,
    4,
    5,
    6,
    7,
    8,
    9
  ],
  "pass_configs": {
    "pass_01_em_dash": {
      "replacement_strategy": "auto"
    },
    "pass_05_contractions": {
      "density": 0.4
    },
    "pass_06_voice_injection": {},
    "pass_09_paraphrase": {
      "mode": "light",
      "mode_by_intensity": {
        "aggressive": "heavy"
      },
      "similarity_threshold": 0.72,
      "default_candidates": 5
    }
  },
  "allowed_filler": [
    "honestly",
    "to be fair",
    "for what it's worth",
    "in my experience",
    "I think",
    "broadly speaking"
  ],
  "allowed_openers": [
    "honestly,",
    "to be fair,",
    "in my experience,",
    "broadly speaking,"
  ],
  "avoid_filler": [
    "lol",
    "tbh",
    "lowkey",
    "fr",
    "ngl"
  ],
  "preserve_em_dashes": false,
  "preserve_oxford_comma": true
}
